{
  "name": "torah-llm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fetch:subset": "tsx ingest/fetch-subset.ts",
    "build:master": "tsx ingest/build-master.ts",
    "slice": "tsx ingest/slice-db.ts",
    "data": "npm run fetch:subset && npm run build:master && npm run slice",
    "publish:master": "tsx ingest/build-publish-master.ts",
    "publish:slice": "MASTER=data/publish-master.sqlite tsx ingest/slice-db.ts",
    "publish:db": "npm run publish:master && npm run publish:slice",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && npm run build:plugins && rm -rf dist/assets dist/plugins && mkdir -p dist && cp public/favicon.* public/pwa-*.png public/maskable-*.png public/apple-touch-*.png dist/ && cp -r public/plugins dist/plugins && vite build",
    "build:db": "mkdir -p dist/db && rsync -a --delete public/db/ dist/db/",
    "build:all": "npm run build && npm run build:db",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "build:plugins": "node scripts/build-plugins.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@monaco-editor/react": "^4.7.0",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tanstack/react-table": "^8.21.3",
    "comlink": "^4.4.2",
    "dompurify": "^3.4.9",
    "fzstd": "^0.1.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.8.1",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
